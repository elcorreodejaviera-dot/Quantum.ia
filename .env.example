# Servidor (Railway / producción local)
PORT=4173
HOST=0.0.0.0

# Convex
CONVEX_DEPLOY_KEY=
CONVEX_URL=
CONVEX_DEPLOYMENT=

# Frontend (Vite — se embeben en el bundle del navegador)
VITE_CONVEX_URL=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_HL_NETWORK=mainnet
VITE_WALLETCONNECT_PROJECT_ID=

# Cifrado AES-256-GCM para credenciales API de wallets HL
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Clave LEGACY (id "legacy"). NO borrar mientras existan credenciales cifradas con ella.
HL_CREDENTIALS_ENCRYPTION_KEY=

# (JAV-63) Rotación de clave — OPCIONALES (default = solo legacy, comportamiento actual):
#  HL_CREDENTIALS_KEYRING: JSON {"<id>":"<secreto>"} con claves ADICIONALES (no redefinir "legacy").
#  HL_CREDENTIALS_ACTIVE_KEY_ID: id con el que se CIFRA lo nuevo (default "legacy").
# Procedimiento de rotación en docs/key-rotation-jav63.md. NO setear ACTIVE_KEY_ID a un id ausente
# del keyring (falla-cerrado al cifrar/re-cifrar). Mantener la clave vieja hasta confirmar estabilidad.
# HL_CREDENTIALS_KEYRING={"v2":"<hex-32-bytes>"}
# HL_CREDENTIALS_ACTIVE_KEY_ID=

# Linear (solo CLI local; no se expone al frontend)
LINEAR_API_KEY=
