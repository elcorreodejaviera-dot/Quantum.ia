{
  "name": "quantum-ia",
  "version": "1.0.0",
  "private": true,
  "description": "Quantum.ia liquidity, spot and hedge bot portal.",
  "scripts": {
    "dev": "vite",
    "dev:testnet": "VITE_HL_NETWORK=testnet vite",
    "linear": "node scripts/linear.mjs",
    "typecheck": "tsc -p convex/tsconfig.json --noEmit",
    "build": "npm run typecheck && vite build && node node_modules/convex/bin/main.js deploy --yes",
    "preview": "vite preview",
    "start": "node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.7",
    "@nktkas/hyperliquid": "^0.32.2",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "convex": "^1.39.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "viem": "^2.52.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.3.5"
  }
}
